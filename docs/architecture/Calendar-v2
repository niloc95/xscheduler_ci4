javascriptexport class DayView {
  render(container, data) {
    const { currentDate, appointments, providers, config } = data;

    const BIZ_START = parseInt(config.slotMinTime);
    const BIZ_END   = parseInt(config.slotMaxTime);
    const HOUR_H    = 64;
    const GRID_H    = (BIZ_END - BIZ_START) * HOUR_H;

    const activeProviders = providers.filter(p =>
      this.scheduler.visibleProviders.has(p.id)
    );
    const colTemplate = `repeat(${activeProviders.length || 1}, 1fr)`;

    const now = DateTime.now().setZone(this.scheduler.options.timezone);
    const isToday = currentDate.hasSame(now, 'day');
    const nowOffset = isToday
      ? ((now.hour - BIZ_START) * 60 + now.minute) / 60 * HOUR_H
      : -1;

    container.innerHTML = `
      <div class="day-view">

        <!-- Provider column headers -->
        <div class="day-provider-header">
          <div class="day-time-spacer"></div>
          <div class="day-provider-cols" style="grid-template-columns:${colTemplate}">
            ${activeProviders.map(p => {
              const cnt = appointments.filter(a =>
                a.startDateTime.hasSame(currentDate, 'day') && a.providerId === p.id
              ).length;
              return `<div class="day-provider-col-header">
                <div class="provider-avatar" style="background:${p.color}">${p.initials}</div>
                <span class="provider-col-name">${p.name.replace('Dr. ', '')}</span>
                <span class="provider-col-count">${cnt}</span>
              </div>`;
            }).join('')}
          </div>
        </div>

        <!-- Scrollable time grid -->
        <div class="day-grid-scroll">
          <div class="day-grid" style="padding-bottom:16px">
            <div class="time-col-labels">
              ${this._timeLabels(BIZ_START, BIZ_END, HOUR_H)}
            </div>
            <div class="day-provider-stripes"
                 style="display:grid;grid-template-columns:${colTemplate};
                        position:relative;min-height:${GRID_H}px">
              ${nowOffset >= 0 ? `
                <div class="now-line" style="top:${nowOffset}px;position:absolute;
                     left:0;right:0;z-index:10">
                  <div class="now-line-dot"></div>
                </div>` : ''}
              ${activeProviders.map(p =>
                this._providerStripe(p, appointments, currentDate, BIZ_START, HOUR_H, GRID_H)
              ).join('')}
            </div>
          </div>
        </div>

      </div>
    `;

    this._attachListeners(container);
  }

  _providerStripe(provider, appointments, date, bizStart, hourH, gridH) {
    const appts = resolveOverlaps(
      appointments.filter(a =>
        a.startDateTime.hasSame(date, 'day') && a.providerId === provider.id
      )
    );
    const blocks = appts.map(a => {
      const top    = ((a.startDateTime.hour - bizStart) * 60 + a.startDateTime.minute) / 60 * hourH;
      const height = Math.max(a.durationMinutes / 60 * hourH - 4, 24);
      const colW   = `${Math.round(100 / a._colCount) - 2}%`;
      const colL   = `${Math.round(a._col * 100 / a._colCount)}%`;
      const isTiny  = height < 28;
      const isShort = height < 42;
      return `
        <div class="appt-block day-appt-block"
          style="top:${top}px;height:${height}px;background:${provider.color};
                 left:calc(4px + ${colL});width:calc(${colW} - 8px)"
          data-appointment-id="${a.id}">
          <div class="appt-block-title">${a.customerName}</div>
          ${!isTiny  ? `<div class="appt-block-sub">${a.serviceName}</div>` : ''}
          ${!isShort ? `<div class="appt-block-time">${a.startDateTime.toFormat('h:mma')}–${a.endDateTime.toFormat('h:mma')}</div>` : ''}
        </div>
      `;
    }).join('');

    return `
      <div class="day-provider-stripe" style="position:relative;min-height:${gridH}px">
        ${this._hourLines(bizStart, bizStart + gridH / hourH, hourH)}
        ${blocks}
      </div>
    `;
  }
}

