This is a standalone module. It renders into .right-panel and is called by SchedulerCore after every state change.
javascriptexport class RightPanel {
  constructor(scheduler) {
    this.scheduler = scheduler;
    this.container = document.getElementById('right-panel-body');
    this._slotCache = new Map(); // key: `${providerId}:${dateStr}` → slots[]
  }

  async render(state) {
    const { currentView, currentDate, providers, appointments } = state;
    this._updateHeader(currentView, currentDate);

    const activeProviders = providers.filter(p =>
      this.scheduler.visibleProviders.has(p.id)
    );

    // Provider cards
    const providerCardsHtml = this._renderProviderCards(
      activeProviders, appointments, currentView, currentDate
    );

    // Slot panel
    const slotPanelHtml = await this._renderSlotPanel(
      activeProviders, currentView, currentDate
    );

    this.container.innerHTML = `
      <div class="rp-section">
        <div class="rp-section-label">
          Providers
          <span>${activeProviders.length} active</span>
        </div>
        ${providerCardsHtml}
      </div>
      ${slotPanelHtml}
    `;

    this._attachListeners();
  }

  /* ── Provider Cards ── */
  _renderProviderCards(providers, appointments, view, date) {
    const dateRange = this._dateRange(view, date);

    return providers.map(provider => {
      const provAppts = appointments.filter(a =>
        a.providerId === provider.id &&
        dateRange.some(d => a.startDateTime.hasSame(d, 'day'))
      );
      const totalSlots  = dateRange.length * (BIZ_END_H - BIZ_START_H) * 2;
      const usedSlots   = provAppts.reduce((acc, a) => acc + Math.ceil(a.durationMinutes / 30), 0);
      const freeSlots   = Math.max(0, totalSlots - usedSlots);
      const loadPct     = Math.min(100, Math.round(usedSlots / Math.max(1, totalSlots) * 100));
      const loadColor   = loadPct > 75 ? '#ef4444' : loadPct > 50 ? '#f59e0b' : '#10b981';
      const confirmed   = provAppts.filter(a => a.status === 'confirmed').length;
      const pending     = provAppts.filter(a => a.status === 'pending').length;

      return `
        <div class="rp-provider-card" data-provider-id="${provider.id}"
             style="--pcolor:${provider.color}">
          <div class="rp-prov-stripe" style="background:${provider.color}"></div>
          <div class="rp-prov-avatar" style="background:${provider.color}">${provider.initials}</div>
          <div class="rp-prov-info">
            <div class="rp-prov-name">${provider.name.replace('Dr. ', '')}</div>
            <div class="rp-prov-role">${provider.role || ''}</div>
            <div class="rp-load-bar">
              <div class="rp-load-fill"
                   style="width:${loadPct}%;background:${loadColor}"></div>
            </div>
          </div>
          <div class="rp-prov-stats">
            <div class="rp-stat">
              <span class="rp-stat-n">${provAppts.length}</span>
              <span class="rp-stat-l">Appts</span>
            </div>
            <div class="rp-stat">
              <span class="rp-stat-n" style="color:#10b981">${freeSlots}</span>
              <span class="rp-stat-l">Free</span>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  /* ── Slot Panel ── */
  async _renderSlotPanel(providers, view, date) {
    // For month view, slot date = today; for others, slot date = currentDate
    const slotDate = (view === 'month')
      ? DateTime.now().setZone(this.scheduler.options.timezone).startOf('day')
      : date.startOf('day');

    const serviceId = this.scheduler.getActiveServiceFilter();
    if (!serviceId) {
      return `
        <div class="rp-section rp-slots-section">
          <div class="rp-section-label">Available Slots</div>
          <div class="rp-no-service">
            <div class="rp-no-svc-icon">🗓</div>
            <div class="rp-no-svc-title">Select a service</div>
            <div class="rp-no-svc-sub">Choose a service in the filter bar to see available time slots</div>
          </div>
        </div>
      `;
    }

    // Fetch slots per provider (uses _slotCache to avoid re-fetching)
    const slotsByProvider = await Promise.all(
      providers.map(p => this._fetchSlots(p.id, serviceId, slotDate))
    );

    // Build hour-grouped slot map
    // key: "HH:MM" → array of { provider, available }
    const slotMap = {};
    slotsByProvider.forEach((slots, idx) => {
      const provider = providers[idx];
      slots.forEach(slot => {
        const key = slot.startTime; // "08:00", "08:30", etc.
        if (!slotMap[key]) slotMap[key] = [];
        slotMap[key].push({ provider, available: slot.available });
      });
    });

    // Group by hour
    const byHour = {};
    Object.entries(slotMap).forEach(([time, provSlots]) => {
      const hour = time.split(':')[0];
      if (!byHour[hour]) byHour[hour] = [];
      byHour[hour].push({ time, provSlots });
    });

    const slotDateLabel = slotDate.hasSame(DateTime.now(), 'day')
      ? 'Today'
      : slotDate.toFormat('EEE d MMM');

    const slotsHtml = Object.keys(byHour)
      .sort()
      .map(hour => {
        const slots = byHour[hour];
        const anyFree = slots.some(s => s.provSlots.some(p => p.available));
        if (!anyFree) return '';
        const h = parseInt(hour);
        const hLabel = h < 12 ? `${h}am` : h === 12 ? '12pm' : `${h - 12}pm`;
        return `
          <div class="slot-hour-group">
            <div class="slot-hour-label">${hLabel}</div>
            <div class="slot-row">
              ${slots
                .filter(s => s.provSlots.some(p => p.available))
                .map(({ time, provSlots }) => {
                  const freeProvs = provSlots.filter(p => p.available);
                  const [hh, mm] = time.split(':');
                  const h12 = parseInt(hh) % 12 || 12;
                  const ap = parseInt(hh) < 12 ? 'a' : 'p';
                  const lbl = `${h12}:${mm}${ap}`;
                  const url = `/appointments/create?date=${slotDate.toISODate()}&time=${time}&service_id=${serviceId}`;
                  return `
                    <a class="slot-pill slot-pill--free"
                       href="${url}"
                       title="${freeProvs.map(p => p.provider.name).join(', ')}">
                      ${freeProvs.map(p =>
                        `<div class="slot-prov-dot" style="background:${p.provider.color}"></div>`
                      ).join('')}
                      ${lbl}
                    </a>
                  `;
                }).join('')}
            </div>
          </div>
        `;
      }).join('');

    return `
      <div class="rp-section rp-slots-section">
        <div class="rp-section-label">
          Available Slots — ${slotDateLabel}
          <span id="free-slot-count">...</span>
        </div>
        <div class="slots-grid">${slotsHtml || '<div class="rp-fully-booked">Fully booked for this day</div>'}</div>
      </div>
    `;
  }

  /* ── Fetch slots with cache ── */
  async _fetchSlots(providerId, serviceId, date) {
    const key = `${providerId}:${serviceId}:${date.toISODate()}`;
    if (this._slotCache.has(key)) return this._slotCache.get(key);

    try {
      const res = await fetch(withBaseUrl(
        `/api/availability/slots?provider_id=${providerId}&service_id=${serviceId}&date=${date.toISODate()}&timezone=UTC`
      ), { headers: { 'X-Requested-With': 'XMLHttpRequest' } });

      if (!res.ok) throw new Error(`${res.status}`);
      const data = await res.json();
      const slots = data?.data?.slots ?? [];
      this._slotCache.set(key, slots);
      // Expire cache after 2 minutes
      setTimeout(() => this._slotCache.delete(key), 120_000);
      return slots;
    } catch {
      return [];
    }
  }

  /* ── Date range helper ── */
  _dateRange(view, date) {
    if (view === 'today' || view === 'day') return [date];
    if (view === 'week') {
      const ws = date.startOf('week');
      return Array.from({ length: 7 }, (_, i) => ws.plus({ days: i }));
    }
    // month
    const start = date.startOf('month');
    const days  = date.daysInMonth;
    return Array.from({ length: days }, (_, i) => start.plus({ days: i }));
  }

  _updateHeader(view, date) {
    const labels = {
      today: 'Today\'s Overview',
      day:   'Day Overview',
      week:  'Week Overview',
      month: 'Monthly Overview',
    };
    document.getElementById('rp-title').textContent = labels[view];

    let dateStr = '';
    if (view === 'today' || view === 'day') {
      dateStr = date.toFormat('EEE, MMMM d yyyy');
    } else if (view === 'week') {
      const ws = date.startOf('week');
      dateStr = `${ws.toFormat('MMM d')} – ${ws.plus({ days: 6 }).toFormat('MMM d')}`;
    } else {
      dateStr = date.toFormat('MMMM yyyy');
    }
    document.getElementById('rp-date').textContent = dateStr;
  }

  _attachListeners() {
    this.container.querySelectorAll('[data-provider-id]').forEach(el => {
      el.addEventListener('click', () => {
        // Optionally filter the calendar to this provider only
      });
    });
  }

  invalidateSlotCache() {
    this._slotCache.clear();
  }
}

