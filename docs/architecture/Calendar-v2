javascript// Cell click handler
_onCellClick(dateStr, event) {
  // If click was on a chip, open appointment details instead
  if (event.target.closest('[data-appointment-id]')) return;

  // Navigate to day view
  const date = DateTime.fromISO(dateStr, { zone: this.scheduler.options.timezone });
  this.scheduler.currentDate = date;
  this.scheduler.changeView('day');
}

// Provider presence dots — one per visible provider
// Filled = has ≥1 appointment that day
// Ring only = 0 appointments
_providerDots(date) {
  return this.visibleProviders.map(provider => {
    const hasAppts = this.appointments.some(a =>
      a.startDateTime.hasSame(date, 'day') && a.providerId === provider.id
    );
    return `<div class="m-prov-dot"
      style="background:${hasAppts ? provider.color : 'transparent'};
             border: 1.5px solid ${provider.color}${hasAppts ? '' : '44'}">
    </div>`;
  }).join('');
}

// Availability bar — bottom of each non-other-month cell
_availBar(date) {
  const totalSlots = this.visibleProviders.length * (BIZ_END_H - BIZ_START_H) * 2;
  const dayAppts = this.appointments.filter(a => a.startDateTime.hasSame(date, 'day'));
  const used = dayAppts.reduce((acc, a) => acc + Math.ceil(a.durationMinutes / 30), 0);
  const pct = Math.max(0, Math.min(100, (1 - used / Math.max(1, totalSlots)) * 100));
  const color = pct > 50 ? '#10b981' : pct > 20 ? '#f59e0b' : '#ef4444';
  return `<div class="m-avail-bar">
    <div class="m-avail-fill" style="width:${pct}%;background:${color}"></div>
  </div>`;
}

View 3 — Week (scheduler-week-view.js) FULL REWRITE
The current 50/50 split week view is deleted entirely. Replace with a proper 7-column time grid.
javascriptexport class WeekView {
  render(container, data) {
    const { currentDate, appointments, providers, config } = data;

    const BIZ_START = parseInt(config.slotMinTime); // 8
    const BIZ_END   = parseInt(config.slotMaxTime); // 17
    const HOUR_H    = 64; // px — matches --hour-height CSS variable
    const GRID_H    = (BIZ_END - BIZ_START) * HOUR_H;

    const ws = this._weekStart(currentDate);
    const days = Array.from({ length: 7 }, (_, i) => ws.plus({ days: i }));

    container.innerHTML = `
      <div class="week-view">

        <!-- Provider filter chips -->
        <div class="week-provider-filter">
          ${providers.map(p => this._providerChip(p)).join('')}
        </div>

        <!-- Day column headers -->
        <div class="week-col-headers">
          <div class="week-time-spacer"></div>
          ${days.map(d => this._colHeader(d, currentDate)).join('')}
        </div>

        <!-- Scrollable time grid -->
        <div class="week-grid-scroll" id="weekGridScroll">
          <div class="week-grid" style="min-height:${GRID_H + 16}px">
            <div class="week-time-col">
              ${this._timeLabels(BIZ_START, BIZ_END, HOUR_H)}
            </div>
            ${days.map(d => this._dayColumn(d, appointments, BIZ_START, HOUR_H, GRID_H)).join('')}
          </div>
        </div>

      </div>
    `;

    this._attachListeners(container);
  }

  _weekStart(dt) {
    // ISO week — Monday = 1
    const wd = dt.weekday; // Luxon: Mon=1, Sun=7
    return dt.minus({ days: wd - 1 }).startOf('day');
  }

  _colHeader(day, currentDate) {
    const isToday = day.hasSame(DateTime.now(), 'day');
    const isSel   = day.hasSame(currentDate, 'day');
    return `
      <div class="week-col-header" data-date="${day.toISODate()}">
        <span class="wk-wd ${isToday ? 'wk-wd--today' : ''}">${day.toFormat('EEE')}</span>
        <div class="wk-day-num ${isToday ? 'wk-day-num--today' : isSel ? 'wk-day-num--sel' : ''}">
          ${day.day}
        </div>
      </div>
    `;
  }

  _dayColumn(day, appointments, bizStart, hourH, gridH) {
    const isToday  = day.hasSame(DateTime.now(), 'day');
    const isWeekend = day.weekday >= 6;
    const dayAppts  = resolveOverlaps(
      appointments.filter(a => a.startDateTime.hasSame(day, 'day'))
    );

    // Now line
    const now = DateTime.now().setZone(this.scheduler.options.timezone);
    const nowOffset = isToday
      ? ((now.hour - bizStart) * 60 + now.minute) / 60 * hourH
      : -1;

    const apptBlocks = dayAppts.map(a => {
      const top = ((a.startDateTime.hour - bizStart) * 60 + a.startDateTime.minute) / 60 * hourH;
      const height = Math.max(a.durationMinutes / 60 * hourH - 3, 20);
      const colW = `${Math.round(100 / a._colCount) - 1}%`;
      const colL = `${Math.round(a._col * 100 / a._colCount)}%`;
      const isTiny  = height < 28;
      const isShort = height < 44;
      return `
        <div class="appt-block"
          style="top:${top}px;height:${height}px;
                 background:${a.providerColor};
                 left:calc(3px + ${colL});width:calc(${colW} - 6px)"
          data-appointment-id="${a.id}">
          <div class="appt-block-title">
            ${isTiny ? a.customerName.split(' ')[0] : a.customerName}
          </div>
          ${!isTiny  ? `<div class="appt-block-sub">${a.serviceName}</div>` : ''}
          ${!isShort ? `<div class="appt-block-time">${a.startDateTime.toFormat('h:mma')}–${a.endDateTime.toFormat('h:mma')}</div>` : ''}
        </div>
      `;
    }).join('');

    return `
      <div class="week-day-col ${isToday ? 'week-day-col--today' : ''} ${isWeekend ? 'week-day-col--weekend' : ''}"
           style="height:${gridH}px">
        ${this._hourLines(bizStart, bizStart + gridH / hourH, hourH)}
        ${nowOffset >= 0 ? `<div class="now-line" style="top:${nowOffset}px"></div>` : ''}
        ${apptBlocks}
      </div>
    `;
  }

  _hourLines(startH, endH, hourH) {
    let html = '';
    for (let h = startH; h <= endH; h++) {
      const top = (h - startH) * hourH;
      html += `<div class="hour-line"     style="top:${top}px"></div>`;
      html += `<div class="half-hour-line" style="top:${top + hourH / 2}px"></div>`;
    }
    return html;
  }

  _attachListeners(container) {
    // Appointment click → flyout
    container.querySelectorAll('[data-appointment-id]').forEach(el => {
      el.addEventListener('click', e => {
        e.stopPropagation();
        this.scheduler.openAppointmentDetails(parseInt(el.dataset.appointmentId));
      });
    });
    // Day header click → drill to Day view
    container.querySelectorAll('[data-date]').forEach(el => {
      el.addEventListener('click', () => {
        const date = DateTime.fromISO(el.dataset.date, { zone: this.scheduler.options.timezone });
        this.scheduler.currentDate = date;
        this.scheduler.changeView('day');
      });
    });
    // Provider chip click → toggle
    container.querySelectorAll('[data-provider-id]').forEach(el => {
      el.addEventListener('click', () =>
        this.scheduler.toggleProvider(parseInt(el.dataset.providerId))
      );
    });
  }
}

