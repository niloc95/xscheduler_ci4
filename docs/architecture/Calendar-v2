javascript// resources/js/modules/scheduler/time-grid-utils.js

export const BIZ_START_H = 8;
export const BIZ_END_H   = 17;
export const HOUR_HEIGHT  = 64; // Must match CSS --hour-height

export function topPx(dt, bizStart = BIZ_START_H) {
  return ((dt.hour - bizStart) * 60 + dt.minute) / 60 * HOUR_HEIGHT;
}

export function heightPx(durationMinutes) {
  return Math.max(durationMinutes / 60 * HOUR_HEIGHT - 3, 20);
}

export function resolveOverlaps(appointments) {
  const sorted = [...appointments].sort(
    (a, b) => a.startDateTime.toMillis() - b.startDateTime.toMillis()
  );
  const colEnds = [];
  const result = sorted.map(appt => {
    let col = 0;
    while (colEnds[col] && colEnds[col] > appt.startDateTime.toMillis()) col++;
    colEnds[col] = appt.endDateTime.toMillis();
    return { ...appt, _col: col };
  });
  const maxCol = result.reduce((m, a) => Math.max(m, a._col), 0);
  return result.map(a => ({ ...a, _colCount: maxCol + 1 }));
}

export function generateTimeLabels(startH = BIZ_START_H, endH = BIZ_END_H) {
  const labels = [];
  for (let h = startH; h <= endH; h++) {
    labels.push({
      hour: h,
      label: h === 0 ? '12am'
           : h < 12  ? `${h}am`
           : h === 12 ? '12pm'
           : `${h - 12}pm`,
    });
  }
  return labels;
}
