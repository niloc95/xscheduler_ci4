This is a new view. Create it.
Purpose: Operational morning briefing. Staff arrives, opens this, sees everything for the day at a glance.
javascriptexport class TodayView {
  constructor(scheduler) { this.scheduler = scheduler; }

  render(container, data) {
    const { currentDate, appointments, providers } = data;

    // Filter to today only
    const todayAppts = appointments
      .filter(a => a.startDateTime.hasSame(currentDate, 'day'))
      .sort((a, b) => a.startDateTime.toMillis() - b.startDateTime.toMillis());

    const now = DateTime.now().setZone(this.scheduler.options.timezone);
    const upcoming = todayAppts.filter(a => a.endDateTime > now);
    const completed = todayAppts.filter(a => a.endDateTime <= now);

    // Stats for hero banner
    const visibleProviders = providers.filter(p =>
      this.scheduler.visibleProviders.has(p.id)
    );
    const totalSlots = visibleProviders.length * (BIZ_END_H - BIZ_START_H) * 2;
    const usedSlots = todayAppts.reduce((acc, a) =>
      acc + Math.ceil(a.durationMinutes / 30), 0
    );
    const freeSlots = Math.max(0, totalSlots - usedSlots);

    container.innerHTML = this._buildHtml({
      currentDate, upcoming, completed, freeSlots,
      total: todayAppts.length
    });

    this._attachListeners(container);
  }

  _buildHtml({ currentDate, upcoming, completed, freeSlots, total }) {
    return `
      <div class="today-view">
        <!-- Hero banner — ocean gradient, full width -->
        <div class="today-hero">
          <div class="today-date">${currentDate.toFormat('EEEE, MMMM d')}</div>
          <div class="today-sub">Here's your schedule for today</div>
          <div class="today-stats">
            <div class="today-stat"><span class="stat-n">${total}</span><span class="stat-l">Total</span></div>
            <div class="today-stat"><span class="stat-n">${upcoming.length}</span><span class="stat-l">Upcoming</span></div>
            <div class="today-stat"><span class="stat-n">${completed.length}</span><span class="stat-l">Done</span></div>
            <div class="today-stat"><span class="stat-n" style="color:#7dd3fc">${freeSlots}</span><span class="stat-l">Free Slots</span></div>
          </div>
        </div>

        <!-- Upcoming appointments -->
        ${upcoming.length ? `
          <div class="today-section-label">Upcoming · ${upcoming.length}</div>
          <div class="today-list" id="today-upcoming">
            ${upcoming.map(a => this._apptRow(a)).join('')}
          </div>
        ` : ''}

        <!-- Completed appointments -->
        ${completed.length ? `
          <div class="today-section-label" style="margin-top:12px">Completed · ${completed.length}</div>
          <div class="today-list today-list--faded" id="today-completed">
            ${completed.map(a => this._apptRow(a)).join('')}
          </div>
        ` : ''}

        ${!total ? '<div class="today-empty">No appointments today</div>' : ''}
      </div>
    `;
  }

  _apptRow(appt) {
    // See prototype for HTML structure
    // Border-left uses provider.color
    // Status pill uses STATUS_COLORS map
    // Click → scheduler.openAppointmentDetails(appt.id)
  }

  _attachListeners(container) {
    container.querySelectorAll('[data-appointment-id]').forEach(el => {
      el.addEventListener('click', () =>
        this.scheduler.openAppointmentDetails(parseInt(el.dataset.appointmentId))
      );
    });
  }
}

