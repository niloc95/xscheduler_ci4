{
  "name": "webschedulr_ci4",
  "version": "2.2.2",
  "minVersion": "1.0.0",
  "type": "module",
  "description": "Modern appointment scheduling system built with CodeIgniter 4",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "mailpit:start": "sh scripts/mailpit-dev.sh start",
    "mailpit:stop": "sh scripts/mailpit-dev.sh stop",
    "mailpit:status": "sh scripts/mailpit-dev.sh status",
    "test:frontend:lifecycle": "node --test tests/frontend/*.test.js",
    "test:unit:calendar": "vitest run tests/unit/calendar/selectors.test.js",
    "test:integration:mysql": "bash scripts/run-mysql-integration-tests.sh",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:header": "playwright test appointments-header",
    "test:e2e:header:headed": "playwright test appointments-header --headed",
    "package": "npm run build && node scripts/package.js",
    "package:archive": "npm run build && node scripts/package.js --archive-logs",
    "package:local": "node scripts/package.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:beta": "node scripts/release.js --beta",
    "release:rc": "node scripts/release.js --rc",
    "release:dry": "node scripts/release.js --dry-run",
    "changelog:preview": "node scripts/release.js --sync-changelog --dry-run",
    "changelog:sync": "node scripts/release.js --sync-changelog"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@coreui/icons": "^3.0.1",
    "chart.js": "^4.5.0",
    "luxon": "^3.7.2",
    "sass": "^1.89.2",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vitest": "^3.2.4"
  }
}
